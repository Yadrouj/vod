# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# local visual smoke outputs
/*smoke*.png
/mag-real-banners-*.png
/mag-real-gym-banner-*.png
/profile-redesign-*.png
/logo-*-smoke.png

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# server-side video cache (downloaded MuscleWiki clips)
/.media-cache/

# serwist (generated service worker)
/public/sw.js
/public/sw.js.map
/public/swe-worker-*.js

# playwright test artifacts
/scripts/e2e-failure.png
/scripts/shots/

# android build outputs
/android/.gradle/
/android/**/build/
/android/local.properties

# local runtime state
/.social-data/coach-chats.json
/.social-data/coach-private-requests.json
/.social-data/messages.json
/.social-data/social-cron-state.json
/.social-data/uploads/
/.social-data/users.json
