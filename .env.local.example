# ─────────────────────────────────────────────────────────────────────────────
# VOD (sarvnema) — server environment.  Copy to `.env.local` and fill in.
#
#   cp .env.local.example .env.local && nano .env.local
#
# `.env.local` is git-ignored. It is read at BUILD time (NEXT_PUBLIC_* get baked
# into the browser bundle) and at run time. Create it BEFORE building if you want
# the public values baked in. The site runs fine with these left blank.
# ─────────────────────────────────────────────────────────────────────────────

# Public site origin (used for absolute/share URLs). Baked in at build time.
NEXT_PUBLIC_SITE_URL=https://sarvnema.ir

# TMDB key exposed to the browser for posters/backdrops. Optional.
NEXT_PUBLIC_TMDB_API_KEY=

# Server bind (already set by docker-compose.prod.yml; override only if needed):
#PORT=3000
#HOSTNAME=0.0.0.0

# --- Telegram watch-party bot (optional; only if you separately run
#     `npm run telegram-bot`). Not needed for the website itself. ---
#BOT_API_TOKEN=
#BOT_SITE_URL=https://sarvnema.ir
#TELEGRAM_BOT_USERNAME=
